  m_TableData:
  - m_Id: 8961519616
    m_Localized: First stack deals {Power} Bio damage; each additional stack deals
      1 less, up to 50 total. Decay with Max Health.
    m_Metadata:
      m_Items:
      - rid: 1998738010735116296
  - m_Id: 821515644928
    m_Localized: Block + {Power} until your next turn.
    m_Metadata:
      m_Items:
      - rid: 1998738010735116296
  - m_Id: 886208589824
    m_Localized: Each point of the applier's Speed above the bearer reduces the bearer's
      Speed by {Power}.
    m_Metadata:
      m_Items:
      - rid: 1998738010735116296
  - m_Id: 912007753728
    m_Localized: All the bearer's actions must target the applier. Decay with Mind.
    m_Metadata:
      m_Items: []
  - m_Id: 5005393918054400
    m_Localized: 'Reduce Accuracy from {Power} to 50. '
    m_Metadata:
      m_Items:
      - rid: 1998738010735116296

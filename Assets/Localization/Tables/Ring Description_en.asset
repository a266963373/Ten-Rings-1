  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Ring Description_en
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: bb9e3674a6d3ebe459006565bb76908b, type: 2}
  m_Metadata:
    m_Items:
    - rid: 5901558492828794900
  m_TableData:
  - m_Id: 34152374272
    m_Localized: 'You feel powerful. Gives you {Power} strength. '
    m_Metadata:
      m_Items:
      - rid: 5901558492828794900
  - m_Id: 303578090115072
    m_Localized: Hurt who dare touches you! After someone melee attacks you, deal
      them {Power} Sharp Grass damage.
    m_Metadata:
      m_Items:
      - rid: 5901558492828794900
  - m_Id: 304238512640000
    m_Localized: It's just hot. Grant you skill "Fireball".
    m_Metadata:
      m_Items: []
  - m_Id: 2499787767967744
    m_Localized: A ring inscribed with knowledge from all disciplines. Grant you
      skill "Omni Lecture".
    m_Metadata:
      m_Items: []
  - m_Id: 2499795581956096
    m_Localized: There is toxin circulating in your body. After you deal Bio damage,
      apply one poison to your target.
    m_Metadata:
      m_Items: []
  - m_Id: 6584876163842048
    m_Localized: 'You feel healthy. Gives you {Power} max health. '
    m_Metadata:
      m_Items:
      - rid: 5901558492828794900
  - m_Id: 6585035681611776
    m_Localized: "From one comes two. After death, generate two weaker versions of
      yourself\u2014one inherits your left-hand rings, the other your right-hand
      rings. Your stats are split evenly between them."
    m_Metadata:
      m_Items: []
  - m_Id: 13543129278754816
    m_Localized: You feel hungry......
    m_Metadata:
      m_Items: []
  - m_Id: 13560337082003456
    m_Localized: 'You feel hasty. Gives you {Power} speed. '
    m_Metadata:
      m_Items:
      - rid: 5901558492828794900
  references:

  m_TableData:
  - m_Id: 4768468992
    m_Localized: Hi! Here to buy or purchase?
    m_Metadata:
      m_Items: []
  - m_Id: 297681883136
    m_Localized: 'I have no idea what they do. Buy it if you are curious! '
    m_Metadata:
      m_Items: []
  - m_Id: 639748345856
    m_Localized: 'Hahaha! No return! '
    m_Metadata:
      m_Items: []
  - m_Id: 1249856000000
    m_Localized: Your support has been noted... Next time I'll bring more rings!
      Thanks!
    m_Metadata:
      m_Items: []
  - m_Id: 1170931781632
    m_Localized: Lets Grow Business Together!
    m_Metadata:
      m_Items: []
  - m_Id: 45425544990720
    m_Localized: No need to sponsor more... I think I have collected all kinds of
      rings in all worlds!
    m_Metadata:
      m_Items: []
  - m_Id: 51527984680960
    m_Localized: You are too poor... but don't worry, I won't despise you for that!
    m_Metadata:
      m_Items: []
  - m_Id: 56186640076800
    m_Localized: You haven't selected anything!
    m_Metadata:
      m_Items: []
